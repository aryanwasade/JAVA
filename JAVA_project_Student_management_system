// Base Class
class Person {
    String name;
    int age;

    // Constructor
    Person(String name, int age) {
        this.name = name;
        this.age = age;
    }

    // Method to display basic details
    void displayPerson() {
        System.out.println("Name: " + name);
        System.out.println("Age: " + age);
    }
}

// Derived Class: Student
class Student extends Person {
    int rollNo;
    double marks;

    // Constructor
    Student(String name, int age, int rollNo, double marks) {
        super(name, age); // Call parent constructor
        this.rollNo = rollNo;
        this.marks = marks;
    }

    // Method to display student details
    void displayStudent() {
        displayPerson();
        System.out.println("Roll Number: " + rollNo);
        System.out.println("Marks: " + marks);
    }
}

// Derived Class: GraduateStudent
class GraduateStudent extends Student {
    String specialization;

    // Constructor
    GraduateStudent(String name, int age, int rollNo, double marks, String specialization) {
        super(name, age, rollNo, marks); // Call parent constructor
        this.specialization = specialization;
    }

    // Method to display full details
    void displayGraduateStudent() {
        displayStudent();
        System.out.println("Specialization: " + specialization);
    }
}

// Main Class
public class StudentManagementSystem {
    public static void main(String[] args) {
        // Creating object
        GraduateStudent gs = new GraduateStudent(
            "Aryan", 21, 101, 85.5, "Computer Science"
        );

        // Display details
        System.out.println("Graduate Student Details:");
        gs.displayGraduateStudent();
    }
}
